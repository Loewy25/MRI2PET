#!/bin/bash
#SBATCH --job-name=resdiff_mri2pet
#SBATCH -N 1
#SBATCH --mem=32G
#SBATCH -t 50:30:00
#SBATCH --gres=gpu:tesla_a100:1
#SBATCH --partition=tier2_gpu
#SBATCH --account=shinjini_kundu
#SBATCH --exclude=gpu02,gpua405,gpu01
#SBATCH --output=slurm-%A_resdiff.out
#SBATCH --error=slurm-%A_resdiff.err

set -euo pipefail

module load cuda/12.2
module load cudnn/9.6.0.74-cuda12

. ~/miniconda3/bin/activate
conda activate pasta

pip install wandb

export PYTHONUNBUFFERED=1
export WANDB__SERVICE_WAIT=300
# Run `wandb login` once on the cluster, or export WANDB_API_KEY before sbatch.

export RUN_NAME="resdiff_fold1_best"
export FOLD_INDEX=0

export MODEL_VARIANT="residual_diffusion"

# Cache generated by tools/cache_baseline_pet.py
export USE_BASELINE_CACHE=1
export BASELINE_CACHE_DIR="/scratch/l.peiwang/pet_base_cache/fold1_res128"

# Fill these from tools/compute_residual_stats.py before launching a real run.
export DIFF_RESIDUAL_MEAN=0.0
export DIFF_RESIDUAL_STD=0.25
export DIFF_X0_CLIP=8.0

export DIFF_TIMESTEPS=1000
export DIFF_UNET_BASE_CH=32
export DIFF_EMB_DIM=128
export DIFF_LR=2e-4
export DIFF_WEIGHT_DECAY=1e-4
export DIFF_LAMBDA_X0=1.0
export DIFF_LAMBDA_ROI=1.0
export DIFF_LAMBDA_BRAAK=0.25

export DIFF_VAL_SAMPLE_STEPS=50
export DIFF_TEST_SAMPLE_STEPS=100
export DIFF_NUM_SAMPLES=8
export VAL_ROI_WEIGHT=0.1

export BATCH_SIZE=1
export EVAL_BATCH_SIZE=1
export AMP_ENABLE=1
export USE_CHECKPOINT=1

export OVERSAMPLE_ENABLE=1
export OVERSAMPLE_LABEL3_TARGET=0.65

# Diffusion conditioning uses cached PET_base, so keep augmentation spatial-only.
export AUG_ENABLE=1
export AUG_PROB=0.5
export AUG_FLIP_PROB=0.5
export AUG_INTENSITY_PROB=0
export AUG_NOISE_STD=0.03
export AUG_SCALE_MIN=0.9
export AUG_SCALE_MAX=1.1
export AUG_SHIFT_MIN=-0.05
export AUG_SHIFT_MAX=0.05

export ROI_HI_Q=0.85
export ROI_HI_LAMBDA=2.5
export ROI_HI_MIN_VOXELS=32

python -u main.py
