#!/bin/bash
#SBATCH --job-name=test #Assign a descriptive job name
#SBATCH -N 1                    # Request 1 node
#SBATCH --mem=20G               # Request 400GB memory
#SBATCH -t 100:30:00             # Set maximum time
##SBATCH --gres=gpu:1
#SBATCH --gres=gpu:nvidia_a100_80:1
#SBATCH --partition=tier2_gpu
#SBATCH --account=shinjini_kundu
#SBATCH --exclude=gpu02
# Output and error filenames based on job ID and task ID
#SBATCH --output=thistest.out
#SBATCH --error=thistest.err


python - <<'PY'
import torch
print("torch:", torch.__version__)
print("cuda available:", torch.cuda.is_available())
print("cuda version:", torch.version.cuda)
print("device count:", torch.cuda.device_count())
PY

set -euo pipefail


module load cuda/12.9
module load cudnn/9.11.0.98-cuda12


 . ~/miniconda3/bin/activate
conda activate pasta

pip install wandb

export WANDB_API_KEY="b8c85c848af247ca775dabc571ae0012a4c36877"
export WANDB__SERVICE_WAIT=300
export PYTHONUNBUFFERED=1
# wandb login 可以省略交互式那句，或者用: wandb login $WANDB_API_KEY

# ---- CV run config ----
export RUN_NAME_PREFIX="long_test"
export RUN_NAME_SUFFIX="os65_aug_7"
export OUT_ROOT="/home/l.peiwang/MRI2PET"
export ROI_ROOT="/scratch/l.peiwang/kari_all"
export META_CSV="/scratch/l.peiwang/MR_AMY_TAU_CDR_merge_DF26.csv"

# Train/val use batch size 2; test/export stays batch size 1 to preserve per-subject outputs.
export BATCH_SIZE=2
export TEST_BATCH_SIZE=1

# Validation-driven scheduling / stopping
export LR_PLATEAU_FACTOR=0.5
export LR_PLATEAU_PATIENCE=20
export EARLY_STOP_PATIENCE=30

# Oversampling (train only)
export OVERSAMPLE_ENABLE=1
export OVERSAMPLE_LABEL3_TARGET=0.65

# Augmentation (train only)
export AUG_ENABLE=1
export AUG_PROB=0.7
export AUG_FLIP_PROB=0.5
export AUG_INTENSITY_PROB=0.8
export AUG_NOISE_STD=0.03
export AUG_SCALE_MIN=0.9
export AUG_SCALE_MAX=1.1
export AUG_SHIFT_MIN=-0.05
export AUG_SHIFT_MAX=0.05

# High-uptake ROI loss (inside cortex mask)
export ROI_HI_Q=0.85
export ROI_HI_LAMBDA=2.5
export ROI_HI_MIN_VOXELS=32

declare -a VOLS_ROOTS=()

for FOLD_INDEX in 0 1 2 3 4; do
  export FOLD_INDEX
  FOLD_NUM=$((FOLD_INDEX + 1))
  export RUN_NAME="${RUN_NAME_PREFIX}_fold${FOLD_NUM}_${RUN_NAME_SUFFIX}"
  echo "=== [$(date)] Starting fold ${FOLD_NUM}/5: RUN_NAME=${RUN_NAME} ==="
  python -u main.py
  VOLS_ROOTS+=("${OUT_ROOT}/${RUN_NAME}/volumes")
  echo "=== [$(date)] Finished fold ${FOLD_NUM}/5 ==="
done

RESULT_DIR="${OUT_ROOT}/${RUN_NAME_PREFIX}_${RUN_NAME_SUFFIX}_RESULT"
mkdir -p "${RESULT_DIR}"

echo "=== [$(date)] Starting integrated comprehensive evaluation ==="
python -u eval_taupet_comprehensive.py \
  --roi-root "${ROI_ROOT}" \
  --vols-roots "${VOLS_ROOTS[@]}" \
  --meta-csv "${META_CSV}" \
  --session-col TAU_PET_Session \
  --split-by braak \
  --thr-braak 1.2 \
  --out "${RESULT_DIR}"
echo "=== [$(date)] Finished integrated comprehensive evaluation ==="

