#!/bin/bash
#SBATCH --job-name=baseline_f5_os5_aug5
#SBATCH -N 1
#SBATCH --mem=10G
#SBATCH -t 50:30:00
#SBATCH --gres=gpu:tesla_a100:1
#SBATCH --partition=tier2_gpu
#SBATCH --account=shinjini_kundu
#SBATCH --exclude=gpu02
#SBATCH --output=slurm-%A_baseline.out
#SBATCH --error=slurm-%A_baseline.err

module load cuda/12.2
module load cudnn/9.6.0.74-cuda12

. ~/miniconda3/bin/activate
conda activate pasta

pip install wandb

export WANDB__SERVICE_WAIT=300
# export WANDB_API_KEY="your_key_here"

export RUN_NAME="batch1_128_new_baseline_fold2_os5_aug_5_rerun"
export FOLD_INDEX=1

export MODEL_VARIANT="baseline"

# Oversampling
export OVERSAMPLE_ENABLE=1
export OVERSAMPLE_LABEL3_TARGET=0.5

# Augmentation
export AUG_ENABLE=1
export AUG_PROB=0.5
export AUG_FLIP_PROB=0.5
export AUG_INTENSITY_PROB=0.8
export AUG_NOISE_STD=0.03
export AUG_SCALE_MIN=0.9
export AUG_SCALE_MAX=1.1
export AUG_SHIFT_MIN=-0.05
export AUG_SHIFT_MAX=0.05

# ROI loss
export ROI_HI_Q=0.85
export ROI_HI_LAMBDA=2.5
export ROI_HI_MIN_VOXELS=32

python main.py


