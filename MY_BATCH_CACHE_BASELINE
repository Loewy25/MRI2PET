#!/bin/bash
#SBATCH --job-name=cache_petbase
#SBATCH -N 1
#SBATCH --mem=32G
#SBATCH -t 08:00:00
#SBATCH --gres=gpu:tesla_a100:1
#SBATCH --partition=tier2_gpu
#SBATCH --account=shinjini_kundu
#SBATCH --exclude=gpu02,gpua405,gpu01
#SBATCH --output=slurm-%A_cache_petbase.out
#SBATCH --error=slurm-%A_cache_petbase.err

set -euo pipefail

module load cuda/12.2
module load cudnn/9.6.0.74-cuda12

. ~/miniconda3/bin/activate
conda activate pasta

export PYTHONUNBUFFERED=1

# Choose the fold and matching baseline checkpoint before submitting.
export FOLD_INDEX=4
export ROOT_DIR="/scratch/l.peiwang/kari_flair_all"

# IMPORTANT: use the baseline best_G.pth trained for the same fold.
export BASE_PRETRAIN_CKPT="/home/l.peiwang/MRI2PET/2025baseline_flair_fold5_os65/checkpoints/best_G.pth"

# Output cache for this fold/model grid.
export BASELINE_CACHE_DIR="/scratch/l.peiwang/pet_base_cache/fold5_res128"

mkdir -p "${BASELINE_CACHE_DIR}"

python -u tools/cache_baseline_pet.py \
  --checkpoint "${BASE_PRETRAIN_CKPT}" \
  --cache-dir "${BASELINE_CACHE_DIR}" \
  --root-dir "${ROOT_DIR}"
